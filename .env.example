# --- Offline / network ---
# When true, the app actively blocks any outbound connection to a host that
# is not in ALLOWED_HOSTS. See app/network_guard.py.
OFFLINE_MODE=true

# Comma-separated list of hosts the app is allowed to reach when OFFLINE_MODE=true.
# Keep this restricted to loopback (the local LLM/OCR servers).
ALLOWED_HOSTS=127.0.0.1,localhost,::1

# --- LLM ---
# "ollama": local-only, the only backend allowed when OFFLINE_MODE=true.
# "gemini": calls the public Gemini API - DEMO ONLY, requires OFFLINE_MODE=false
#           and GEMINI_API_KEY. Do not use with real patient data.
LLM_BACKEND=ollama

# Local LLM (Ollama, running on this host)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llava

# Demo-only cloud LLM (Google Gemini). Requires OFFLINE_MODE=false.
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# --- OCR (future use, pluggable) ---
OCR_ENGINE=paddleocr
OCR_MODEL_DIR=/opt/health_hackathon/models/ocr

# PaddleOCR model directories (must be pre-downloaded, no runtime download)
PADDLEOCR_DET_MODEL_DIR=/opt/health_hackathon/models/paddleocr/det
PADDLEOCR_REC_MODEL_DIR=/opt/health_hackathon/models/paddleocr/rec
PADDLEOCR_CLS_MODEL_DIR=/opt/health_hackathon/models/paddleocr/cls

# Tesseract (only used if OCR_ENGINE=tesseract)
TESSDATA_PREFIX=/opt/health_hackathon/models/tessdata

# --- Uploads ---
UPLOAD_TMP_DIR=/tmp/health_hackathon_uploads
